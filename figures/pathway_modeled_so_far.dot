digraph ADHD_Modeled_Flow {
  rankdir=LR;
  splines=ortho;
  fontname="Helvetica";
  graph [bgcolor="white", pad="0.08", nodesep="0.22", ranksep="0.32"];
  node [shape=box, style="rounded,filled", fillcolor="#f8fbff", color="#2b6cb0", fontname="Helvetica", margin="0.08,0.05"];
  edge [color="#4a5568", arrowsize=0.7, penwidth=1.0];

  subgraph cluster_flow {
    label="Modeled Pathway (Phase 1)";
    color="#90cdf4";
    style="rounded";
    margin=8;

    A [label="Patient Arrivals\nExponential inter-arrival"];
    B [label="Screening Queue"];
    C [label="Screening Service\nTriangular time"];
    D [label="Triage Queue"];
    E [label="Triage Service\nTriangular time"];
    F [label="Assessment Queue"];
    G [label="Assessment Service\nLogNormal time"];
    H [label="Exit"];

    A -> B -> C -> D -> E -> F -> G -> H;
  }
}
